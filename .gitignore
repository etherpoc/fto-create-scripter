data/training.csv

# SSL 証明書 / 秘密鍵 (mkcert やローカル生成)
# 公開鍵は再生成手順を README に書く方針。秘密鍵は決してコミットしない。
server/certs/*-key.pem
server/certs/*.key
server/certs/*.pem

